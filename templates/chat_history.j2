{% for msg in messages %}
{% if msg.role == "user" %}
[{{ msg.timestamp }}] {{ user }}:
{{ msg.content }}

{% elif msg.role == "assistant" %}
[{{ msg.timestamp }}] sloth-agent:
{{ msg.content }}
{% if msg.tool_calls %}
  Tools: {% for tc in msg.tool_calls %}{{ tc }}{% if not loop.last %}, {% endif %}{% endfor %}
{% endif %}

{% elif msg.role == "tool" %}
[{{ msg.timestamp }}] tool({{ msg.tool_name }}):
{{ msg.content | truncate(500) }}

{% endif %}
{% endfor %}
